{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Sample Claude Code settings for agent-skills-core. Hooks live in scripts/claude-hooks/ so they can be tested independently. typecheck-after-edit.sh is a no-op in non-TS repos.",
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(gh pr*)",
      "Bash(gh issue*)",
      "Bash(gh repo*)",
      "Bash(gh project*)",
      "Bash(gh api*)",
      "Bash(gh run*)",
      "Bash(gh release*)",
      "Bash(gh auth status*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/claude-hooks/block-main-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/claude-hooks/typecheck-after-edit.sh"
          }
        ]
      }
    ]
  }
}
